from selenium import webdriver
from selenium.webdriver.common.by import By
import time

driver = webdriver.Chrome()

driver.get("https://demo.openemr.io/openemr/interface/login/login.php")
time.sleep(3)

# Login first
driver.find_element(By.ID, "authUser").send_keys("admin")
driver.find_element(By.ID, "clearPass").send_keys("pass")
driver.find_element(By.ID, "login-button").click()

time.sleep(5)

print("Logged in successfully")


try:
    driver.find_element(By.LINK_TEXT, "Calendar").click()
    time.sleep(3)
    print("TC04: Navigated to Appointment Page")

except:
    print("TC04: Navigation Failed")

driver.quit()
